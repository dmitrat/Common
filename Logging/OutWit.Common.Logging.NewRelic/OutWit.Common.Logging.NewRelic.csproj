	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\Rest\OutWit.Common.Rest\OutWit.Common.Rest.csproj" />
		<ProjectReference Include="..\..\Serialization\MemoryPack\OutWit.Common.MemoryPack\OutWit.Common.MemoryPack.csproj" />
		<ProjectReference Include="..\OutWit.Common.Logging.Query\OutWit.Common.Logging.Query.csproj" />
	</ItemGroup>

</Project>
