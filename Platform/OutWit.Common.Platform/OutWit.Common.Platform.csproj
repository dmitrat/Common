<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net10.0;net9.0;net8.0;net7.0;net6.0</TargetFrameworks>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<LangVersion>latest</LangVersion>

		<Version>1.0.1</Version>

		<Description>Cross-platform helpers for collecting machine system information (OS / CPU / GPU / memory / storage / health), a stable machine identity, and semantic standard directories. Internal Strategy split per OS makes it easy to add new platforms (Windows, Linux, macOS, Android out of the box).</Description>
		<PackageTags>OutWit;Common;Platform;SystemInfo;Health;Directories;CrossPlatform;Android</PackageTags>

		<RepositoryUrl>https://github.com/dmitrat/Common/tree/main/Platform/OutWit.Common.Platform</RepositoryUrl>
	</PropertyGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="OutWit.Common.Platform.Tests" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="OutWit.Common" Version="1.3.*" />
	</ItemGroup>

	<!--
	System.Management (WMI) and PerformanceCounter are Windows-only at runtime but
	the NuGet packages ship reference assemblies for every TFM we target. They are
	pulled in unconditionally so PlatformProbeWindows compiles on cross-OS builds;
	runtime calls are gated by OperatingSystem.IsWindows() before the type is used.
	-->
	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
		<PackageReference Include="System.Management" Version="10.0.5" />
		<PackageReference Include="System.Diagnostics.PerformanceCounter" Version="10.0.5" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net9.0' or '$(TargetFramework)' == 'net8.0'">
		<PackageReference Include="System.Management" Version="9.0.12" />
		<PackageReference Include="System.Diagnostics.PerformanceCounter" Version="9.0.12" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net7.0' or '$(TargetFramework)' == 'net6.0'">
		<PackageReference Include="System.Management" Version="8.0.0" />
		<PackageReference Include="System.Diagnostics.PerformanceCounter" Version="8.0.1" />
	</ItemGroup>

</Project>
